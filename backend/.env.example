PORT=5001
NODE_ENV=production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
ALLOWED_ORIGINS=https://your-app.netlify.app

# Email (SMTP) — required for sending hiring agreement sign links
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
COMPANY_NAME=Your Company Name

# AI Agent — get key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# TBC Bank Integration — get credentials from developer.tbcbank.ge
TBC_API_BASE_URL=https://api.tbcbank.ge/v1
TBC_API_KEY=your-tbc-api-key
TBC_CLIENT_ID=your-tbc-client-id
TBC_CLIENT_SECRET=your-tbc-client-secret
BACKEND_URL=http://localhost:5001
FRONTEND_URL=http://localhost:3000

# RS.ge Integration (Revenue Service of Georgia)
# Create a service user at rs.ge > My Page > Service Users
RS_SERVICE_USER=your-rs-service-user
RS_SERVICE_PASSWORD=your-rs-service-password
RS_COMPANY_TIN=your-company-identification-number
